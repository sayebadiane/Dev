<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_payment_receipt" model="ir.actions.report">
        <field name="name">Reçu de paiement</field>
        <field name="model">school.payment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">school_management.report_payment_receipt_template</field>
        <field name="report_file">school_management.report_payment_receipt_template</field>
        <field name="binding_model_id" ref="model_school_payment"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>

    <template id="report_payment_receipt_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- En-tête reçu -->
                        <div class="text-center mb-4"
                             style="border-bottom: 2px solid #27ae60; padding-bottom: 10px;">
                            <h3 style="color: #27ae60;">REÇU DE PAIEMENT DE SCOLARITÉ</h3>
                            <p style="font-size: 12px;">Référence : <strong>
                                <t t-esc="doc.name"/>
                            </strong></p>
                        </div>

                        <!-- Informations élève -->
                        <div class="row mb-3">
                            <div class="col-6">
                                <table style="font-size: 12px;">
                                    <tr>
                                        <td style="padding: 4px; font-weight: bold;">Élève :</td>
                                        <td style="padding: 4px;">
                                            <t t-esc="doc.student_id.full_name"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 4px; font-weight: bold;">Matricule :</td>
                                        <td style="padding: 4px;">
                                            <t t-esc="doc.student_id.registration_number"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 4px; font-weight: bold;">Classe :</td>
                                        <td style="padding: 4px;">
                                            <t t-esc="doc.class_id.name or '-'"/>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-6">
                                <table style="font-size: 12px;">
                                    <tr>
                                        <td style="padding: 4px; font-weight: bold;">Période :</td>
                                        <td style="padding: 4px;"><t t-esc="doc.period"/></td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 4px; font-weight: bold;">Date limite :</td>
                                        <td style="padding: 4px;">
                                            <span t-field="doc.due_date"
                                                  t-options='{"format": "dd/MM/yyyy"}'/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 4px; font-weight: bold;">Statut :</td>
                                        <td style="padding: 4px;">
                                            <strong>
                                                <t t-if="doc.state == 'paid'">
                                                    <span style="color: #27ae60;">PAYÉ</span>
                                                </t>
                                                <t t-elif="doc.state == 'partial'">
                                                    <span style="color: #e67e22;">PARTIEL</span>
                                                </t>
                                                <t t-else="">
                                                    <span style="color: #c0392b;">IMPAYÉ</span>
                                                </t>
                                            </strong>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- Résumé des montants -->
                        <table class="table table-bordered" style="font-size: 12px;">
                            <tr style="background-color: #ecf0f1;">
                                <td><strong>Montant dû</strong></td>
                                <td class="text-right">
                                    <t t-esc="'{:,.0f}'.format(doc.amount_due)"/> FCFA
                                </td>
                            </tr>
                            <tr>
                                <td><strong>Total versé</strong></td>
                                <td class="text-right" style="color: #27ae60;">
                                    <t t-esc="'{:,.0f}'.format(doc.amount_paid)"/> FCFA
                                </td>
                            </tr>
                            <tr style="background-color: #fadbd8;" t-if="doc.amount_remaining > 0">
                                <td><strong>Reste à payer</strong></td>
                                <td class="text-right" style="color: #c0392b; font-weight: bold;">
                                    <t t-esc="'{:,.0f}'.format(doc.amount_remaining)"/> FCFA
                                </td>
                            </tr>
                        </table>

                        <!-- Détail des versements -->
                        <t t-if="doc.line_ids">
                            <h5 class="mt-3">Détail des versements</h5>
                            <table class="table table-bordered table-sm" style="font-size: 11px;">
                                <thead style="background-color: #2c3e50; color: white;">
                                    <tr>
                                        <th>Date</th>
                                        <th>Montant (FCFA)</th>
                                        <th>Mode</th>
                                        <th>Reçu par</th>
                                        <th>Note</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="doc.line_ids" t-as="line">
                                        <tr>
                                            <td>
                                                <span t-field="line.date"
                                                      t-options='{"format": "dd/MM/yyyy"}'/>
                                            </td>
                                            <td class="text-right">
                                                <t t-esc="'{:,.0f}'.format(line.amount)"/>
                                            </td>
                                            <td><t t-esc="dict(line._fields['payment_method'].selection).get(line.payment_method, '-')"/></td>
                                            <td><t t-esc="line.received_by.name or '-'"/></td>
                                            <td><t t-esc="line.note or ''"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <!-- Pied de page reçu -->
                        <div class="row mt-4">
                            <div class="col-6">
                                <p style="font-size: 11px; color: #7f8c8d;">
                                    Document généré le
                                    <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y à %H:%M')"/>
                                </p>
                            </div>
                            <div class="col-6 text-right">
                                <p><strong>Signature et cachet de l'école</strong></p>
                                <br/>
                                <p style="border-top: 1px solid #333; display: inline-block; width: 150px;"></p>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
