<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_school_parent_form" model="ir.ui.view">
        <field name="name">school.parent.form</field>
        <field name="model">school.parent</field>
        <field name="arch" type="xml">
            <form string="Parent / Tuteur">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_students" type="object"
                                class="oe_stat_button" icon="fa-users">
                            <field name="student_count" widget="statinfo" string="Enfants"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="firstname" placeholder="Prénom"/>
                            <field name="name" placeholder="NOM"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Informations personnelles">
                            <field name="relationship"/>
                            <field name="phone"/>
                            <field name="phone2"/>
                            <field name="email"/>
                            <field name="profession"/>
                        </group>
                        <group string="Adresse">
                            <field name="address"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Enfants inscrits">
                            <field name="student_ids">
                                <list string="Enfants">
                                    <field name="registration_number"/>
                                    <field name="full_name"/>
                                    <field name="class_id"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'active'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_school_parent_list" model="ir.ui.view">
        <field name="name">school.parent.list</field>
        <field name="model">school.parent</field>
        <field name="arch" type="xml">
            <list string="Parents / Tuteurs">
                <field name="full_name"/>
                <field name="relationship"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="profession"/>
                <field name="student_count"/>
            </list>
        </field>
    </record>

    <record id="view_school_parent_search" model="ir.ui.view">
        <field name="name">school.parent.search</field>
        <field name="model">school.parent</field>
        <field name="arch" type="xml">
            <search string="Rechercher un parent">
                <field name="name"/>
                <field name="firstname"/>
                <field name="phone"/>
                <field name="email"/>
                <filter string="Pères" name="fathers" domain="[('relationship', '=', 'father')]"/>
                <filter string="Mères" name="mothers" domain="[('relationship', '=', 'mother')]"/>
                <filter string="Tuteurs" name="guardians" domain="[('relationship', '=', 'guardian')]"/>
                <group name="group_by">
                    <filter string="Lien de parenté" name="group_rel"
                            context="{'group_by': 'relationship'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_school_parent" model="ir.actions.act_window">
        <field name="name">Parents / Tuteurs</field>
        <field name="res_model">school.parent</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_school_parent_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucun parent enregistré
            </p>
        </field>
    </record>
</odoo>
