<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_school_class_form" model="ir.ui.view">
        <field name="name">school.class.form</field>
        <field name="model">school.class</field>
        <field name="arch" type="xml">
            <form string="Classe">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_students" type="object"
                                class="oe_stat_button" icon="fa-users">
                            <field name="student_count" widget="statinfo" string="Élèves"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nom de la classe"/></h1>
                    </div>
                    <group>
                        <group string="Informations">
                            <field name="level"/>
                            <field name="school_year"/>
                            <field name="teacher_id"/>
                            <field name="room"/>
                            <field name="capacity"/>
                            <field name="active"/>
                        </group>
                        <group string="Scolarité">
                            <field name="monthly_fee"/>
                        </group>
                    </group>
                    <div class="mt16">
                        <button name="action_create_monthly_payments" type="object"
                                string="Générer factures du mois" class="btn btn-primary"/>
                        <button name="action_mark_attendance" type="object"
                                string="Saisir présences" class="btn btn-secondary ml8"/>
                    </div>
                    <notebook>
                        <page string="Liste des élèves">
                            <field name="student_ids" readonly="1">
                                <list string="Élèves" decoration-muted="state == 'inactive'">
                                    <field name="registration_number"/>
                                    <field name="full_name"/>
                                    <field name="gender"/>
                                    <field name="phone"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'active'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_school_class_list" model="ir.ui.view">
        <field name="name">school.class.list</field>
        <field name="model">school.class</field>
        <field name="arch" type="xml">
            <list string="Classes" decoration-muted="not active">
                <field name="name"/>
                <field name="level"/>
                <field name="school_year"/>
                <field name="teacher_id"/>
                <field name="student_count"/>
                <field name="capacity"/>
                <field name="monthly_fee"/>
            </list>
        </field>
    </record>

    <record id="view_school_class_search" model="ir.ui.view">
        <field name="name">school.class.search</field>
        <field name="model">school.class</field>
        <field name="arch" type="xml">
            <search string="Rechercher une classe">
                <field name="name"/>
                <field name="school_year"/>
                <field name="teacher_id"/>
                <filter string="Actives" name="active" domain="[('active', '=', True)]"/>
                <filter string="Année courante" name="current_year"
                        domain="[('school_year', '=', '2024-2025')]"/>
                <group name="group_by">
                    <filter string="Niveau" name="group_level" context="{'group_by': 'level'}"/>
                    <filter string="Année scolaire" name="group_year" context="{'group_by': 'school_year'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_school_class" model="ir.actions.act_window">
        <field name="name">Classes</field>
        <field name="res_model">school.class</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_school_class_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune classe enregistrée
            </p>
        </field>
    </record>
</odoo>
