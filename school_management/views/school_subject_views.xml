<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_school_subject_form" model="ir.ui.view">
        <field name="name">school.subject.form</field>
        <field name="model">school.subject</field>
        <field name="arch" type="xml">
            <form string="Matière">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="coefficient"/>
                        <field name="teacher_id"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_school_subject_list" model="ir.ui.view">
        <field name="name">school.subject.list</field>
        <field name="model">school.subject</field>
        <field name="arch" type="xml">
            <list string="Matières" editable="bottom" decoration-muted="not active">
                <field name="name"/>
                <field name="code"/>
                <field name="coefficient"/>
                <field name="teacher_id"/>
                <field name="active" optional="show"/>
            </list>
        </field>
    </record>

    <record id="action_school_subject" model="ir.actions.act_window">
        <field name="name">Matières</field>
        <field name="res_model">school.subject</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
