<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Menu principal -->
    <menuitem id="menu_school_root"
              name="École"
              sequence="10"
              web_icon="school_management,static/description/icon.png"/>

    <!-- Tableau de bord -->
    <menuitem id="menu_school_dashboard"
              name="Tableau de bord"
              parent="menu_school_root"
              action="action_school_dashboard"
              sequence="1"/>

    <!-- Élèves -->
    <menuitem id="menu_school_students"
              name="Élèves"
              parent="menu_school_root"
              action="action_school_student"
              sequence="10"/>

    <!-- Classes -->
    <menuitem id="menu_school_classes"
              name="Classes"
              parent="menu_school_root"
              action="action_school_class"
              sequence="20"/>

    <!-- Paiements -->
    <menuitem id="menu_school_payments_root"
              name="Paiements"
              parent="menu_school_root"
              sequence="30"/>

    <menuitem id="menu_school_payments"
              name="Tous les paiements"
              parent="menu_school_payments_root"
              action="action_school_payment"
