    <menuitem id="menu_school_absences"
              name="Présences"
              parent="menu_school_root"
              action="action_school_absence"
              sequence="40"/>

    <!-- Bulletins -->
    <menuitem id="menu_school_bulletins"
              name="Bulletins"
              parent="menu_school_root"
              action="action_school_bulletin"
              sequence="50"/>

    <!-- Parents -->
    <menuitem id="menu_school_parents"
              name="Parents"
              parent="menu_school_root"
              action="action_school_parent"
              sequence="60"/>

    <!-- Configuration -->
    <menuitem id="menu_school_config"
              name="Configuration"
              parent="menu_school_root"
              sequence="100"
              groups="school_management.group_school_manager"/>

    <menuitem id="menu_school_subjects"
              name="Matières"
              parent="menu_school_config"
              action="action_school_subject"
              sequence="1"/>
</odoo>
