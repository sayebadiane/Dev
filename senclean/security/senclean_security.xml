<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Groupe : Utilisateur (visible par tous les utilisateurs internes) -->
    <record id="group_senclean_user" model="res.groups">
        <field name="name">SenClean / Utilisateur</field>
    </record>

    <!-- Groupe : Manager (peut valider prestataires, gérer missions) -->
    <record id="group_senclean_manager" model="res.groups">
        <field name="name">SenClean / Manager</field>
        <field name="implied_ids" eval="[(4, ref('group_senclean_user'))]"/>
    </record>

    <!-- Groupe : Admin (accès complet) -->
    <record id="group_senclean_admin" model="res.groups">
        <field name="name">SenClean / Administrateur</field>
        <field name="implied_ids" eval="[(4, ref('group_senclean_manager'))]"/>
    </record>

    <!-- Tout utilisateur interne Odoo est automatiquement utilisateur SenClean -->
    <record id="base.group_user" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_senclean_user'))]"/>
    </record>

</odoo>
